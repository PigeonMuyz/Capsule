<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Allow debugger to attach (required for Xcode debugging) -->
	<key>com.apple.security.get-task-allow</key>
	<true/>

	<!-- Disable App Sandbox to allow system container access -->
	<key>com.apple.security.app-sandbox</key>
	<false/>

	<!-- Virtualization entitlement (required for Containerization framework) -->
	<key>com.apple.security.virtualization</key>
	<true/>

	<!-- Network access for pulling images and container networking -->
	<key>com.apple.security.network.client</key>
	<true/>

	<!-- Disable library validation to allow executing system binaries -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>

	<!-- Allow executing unsigned code (for container CLI) -->
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
</dict>
</plist>
